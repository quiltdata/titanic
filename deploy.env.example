# Example deployment configuration for Titanic Stack
# Copy this file to .env and customize the values for your environment

# Required Parameters
QUILT_DATABASE_NAME=your_glue_database_name
QUILT_READ_POLICY_ARN=arn:aws:iam::123456789012:policy/YourQuiltReadPolicy

# Optional Parameters
USE_S3_TABLE=false
LAMBDA_TIMEOUT=15000

# AWS Configuration
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=default

# Deployment Examples:
#
# 1. Deploy with environment variables:
#    source .env && ./bin/deploy.sh
#
# 2. Deploy with command line parameters:
#    ./bin/deploy.sh --glue-database-name mydb --quilt-read-policy-arn arn:aws:iam::123456789012:policy/QuiltReadPolicy
#
# 3. Generate template only (dry run):
#    ./bin/deploy.sh --dry-run --glue-database-name mydb --quilt-read-policy-arn arn:aws:iam::123456789012:policy/QuiltReadPolicy
#
# 4. Deploy with S3 Tables enabled:
#    ./bin/deploy.sh --glue-database-name mydb --quilt-read-policy-arn arn:aws:iam::123456789012:policy/QuiltReadPolicy --use-s3-table true
