# Example environment variables for the Titanic project

# AWS Configuration
AWS_DEFAULT_REGION=us-east-2
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# CDK Configuration
CDK_DEFAULT_ACCOUNT=your-account-id
CDK_DEFAULT_REGION=$AWS_DEFAULT_REGION
CDK_BOOTSTRAP=aws://$CDK_DEFAULT_ACCOUNT/$CDK_DEFAULT_REGION

# Quilt Configuration
QUILT_DATABASE_NAME=userathenadatabase-XXXXXXX
QUILT_READ_POLICY_ARN=arn:aws:iam::$CDK_DEFAULT_ACCOUNT:policy/STACK-BucketReadPolicy-XXXX

# Table Configuration
USE_S3_TABLE=false
# Default: false (use Glue tables)
