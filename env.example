# Titanic Stack Configuration
# Copy this file to .env and customize for your environment
# 
# Usage: cp env.example .env && edit .env

# ================================================================
# REQUIRED: Quilt Integration
# ================================================================
ATHENA_DATABASE_NAME=your_athena_database_name
QUILT_READ_POLICY_ARN=arn:aws:iam::123456789012:policy/YourQuiltReadPolicy

# ================================================================
# OPTIONAL: AWS Settings  
# ================================================================
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=default

# ================================================================
# DEPLOYMENT EXAMPLES
# ================================================================
#
# 1. Copy and edit this file (recommended):
#    cp env.example .env
#    # Edit .env with your values
#    ./deploy.sh
#
# 2. Deploy with command line parameters:
#    ./deploy.sh --athena-database-name mydb --quilt-read-policy-arn arn:aws:iam::123456789012:policy/QuiltReadPolicy
#
# 3. Use environment variables directly:
#    ATHENA_DATABASE_NAME=mydb QUILT_READ_POLICY_ARN=arn:aws:iam::123456789012:policy/QuiltReadPolicy ./deploy.sh
