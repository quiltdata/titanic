{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Tests",
			"type": "process",
			"command": "npm",
			"args": [
				"test"
			],
			"group": "test",
			"isBackground": false,
			"problemMatcher": [],
			"runOptions": {
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": true
			}
		},
		{
			"label": "Run Tests (Watch Mode)",
			"type": "process",
			"command": "npm",
			"args": [
				"run",
				"test",
				"--",
				"--watch"
			],
			"group": "test",
			"problemMatcher": [],
			"runOptions": {
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": true
			}
		},
		{
			"label": "Run Tests (Coverage)",
			"type": "process",
			"command": "npm",
			"args": [
				"run",
				"test",
				"--",
				"--coverage"
			],
			"group": "test",
			"isBackground": false,
			"problemMatcher": [],
			"runOptions": {
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": true
			}
		},
		{
			"label": "Run Specific Test File",
			"type": "process",
			"command": "npm",
			"args": [
				"run",
				"test",
				"--",
				"${input:testFile}"
			],
			"group": "test",
			"isBackground": false,
			"problemMatcher": [],
			"runOptions": {
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": true
			}
		},
		{
			"label": "Run Fast Tests",
			"type": "process",
			"command": "jest",
			"args": [
				"--runInBand",
				"--no-cache"
			],
			"group": "test",
			"isBackground": false,
			"problemMatcher": [],
			"runOptions": {
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": true
			}
		}
	],
	"inputs": [
		{
			"id": "testFile",
			"description": "Test file to run",
			"default": "",
			"type": "promptString"
		}
	]
}