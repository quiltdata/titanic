{
  "name": "titanic",
  "version": "0.2.0",
  "bin": {
    "titanic": "bin/titanic.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf cdk.out **/{*.js,*.d.ts} test-results node_modules coverage",
    "cdk": "npm run test && npx cdk deploy --require-approval never && npm run event && npm run logs:delayed",
    "lint": "eslint . --ext .ts --fix",
    "event": "dotenv -- ./bin/send-event.sh",
    "logs": "dotenv -- ./bin/monitor-logs.sh",
    "logs:delayed": "sleep 20 && npm run logs recent 1",
    "outputs": "dotenv -- aws cloudformation describe-stacks --stack-name TitanicStack --query 'Stacks[0].Outputs'",
    "destroy": "npm run destroy:buckets && npx cdk destroy --force",
    "destroy:buckets": "dotenv -- ./bin/cleanup-buckets.sh",
    "destroy:buckets:contents": "dotenv -- ./bin/cleanup-buckets.sh --contents-only",
    "test": "jest --no-coverage",
    "test:coverage": "jest --coverage --verbose",
    "test:fails": "jest --onlyFailures --verbose",
    "test:watch": "jest --watch --verbose",
    "test:debug": "jest --verbose --no-coverage --runInBand --detectOpenHandles",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/jest": "^30.0.0",
    "@types/node": "22.16.2",
    "aws-cdk": "2.1020.2",
    "aws-sdk-client-mock": "^4.1.0",
    "jest": "^30.0.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.0",
    "dotenv-cli": "^7.0.0"
  },
  "dependencies": {
    "@aws-cdk/aws-lambda-event-sources": "^1.203.0",
    "@aws-cdk/aws-s3tables-alpha": "^2.202.0-alpha.0",
    "@aws-sdk/client-athena": "^3.787.0",
    "@aws-sdk/client-glue": "^3.787.0",
    "aws-cdk-lib": "2.204.0",
    "constructs": "^10.0.0",
    "dotenv": "^17.0.0"
  }
}
