{
  "name": "titanic",
  "version": "0.2.0",
  "bin": {
    "titanic": "bin/titanic.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf cdk.out */**/{*.js,*.d.ts}",
    "cdk": "npm run test && npx cdk deploy --require-approval never && npm run event:bake && npm run logs:delayed",
    "lint": "eslint . --ext .ts --fix",
    "event:all": "aws events put-events --entries file://doc/event-all.json",
    "event:bake": "aws events put-events --entries file://doc/event-quilt-bake.json",
    "event:staff": "aws events put-events --entries file://doc/event-staff.json",
    "logs": "./bin/monitor-logs.sh",
    "logs:delayed": "sleep 20 && npm logs recent 1",
    "outputs": "aws cloudformation describe-stacks --stack-name TitanicStack --query 'Stacks[0].Outputs'",
    "test": "jest --no-coverage",
    "test:coverage": "jest --coverage --verbose",
    "test:fails": "jest --onlyFailures --verbose",
    "test:watch": "jest --watch --verbose",
    "test:debug": "jest --verbose --no-coverage --runInBand --detectOpenHandles",
    "watch": "tsc -w"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/jest": "^30.0.0",
    "@types/node": "22.15.33",
    "aws-cdk": "2.1019.2",
    "aws-sdk-client-mock": "^4.1.0",
    "jest": "^30.0.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.0"
  },
  "dependencies": {
    "@aws-cdk/aws-lambda-event-sources": "^1.203.0",
    "@aws-cdk/aws-s3tables-alpha": "^2.202.0-alpha.0",
    "@aws-sdk/client-athena": "^3.787.0",
    "@aws-sdk/client-glue": "^3.787.0",
    "aws-cdk-lib": "2.202.0",
    "constructs": "^10.0.0",
    "dotenv": "^16.5.0"
  }
}
