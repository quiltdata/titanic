{
  "name": "titanic",
  "version": "0.2.2",
  "bin": {
    "titanic": "bin/titanic.js"
  },
  "scripts": {
    "clean:js": "rm -rf */**/{*.js,*.js.map,*.d.ts} && rm -rf bin/{*.js,*.js.map}",
    "clean": "rm -rf cdk.out test-results node_modules coverage dist",
    "cdk": "npm run test && npx cdk deploy --app 'npx ts-node bin/titanic.ts' --require-approval never && npm run deploy:event && npm run deploy:logs:delayed",
    "cdk:synth": "npx cdk synth --app 'npx ts-node bin/titanic.ts'",
    "cdk:params": "npx cdk synth --app 'npx ts-node bin/titanic-params.ts'",
    "lint": "eslint . --ext .ts --fix",
    "deploy:event": "dotenv -- ./bin/send-event.sh quilt-bake",
    "deploy:logs": "dotenv -- ./bin/monitor-logs.sh",
    "deploy:logs:delayed": "sleep 20 && npm run deploy:logs recent 1",
    "deploy:outputs": "dotenv -- aws cloudformation describe-stacks --stack-name TitanicStack --query 'Stacks[0].Outputs'",
    "deploy:release": "./bin/release.sh",
    "destroy": "npm run destroy:buckets && npx cdk destroy --app 'npx ts-node bin/titanic.ts' --force",
    "destroy:buckets": "dotenv -- ./bin/cleanup-buckets.sh",
    "destroy:buckets:contents": "dotenv -- ./bin/cleanup-buckets.sh --contents-only",
    "test": "jest --no-coverage",
    "test:coverage": "jest --coverage --verbose",
    "test:fails": "jest --onlyFailures --verbose",
    "test:watch": "jest --watch --verbose",
    "test:debug": "jest --verbose --no-coverage --runInBand --detectOpenHandles",
    "s3tables:create": "npx ts-node lib/tables/create-s3-tables.ts all",
    "s3tables:namespace": "npx ts-node lib/tables/create-s3-tables.ts namespace",
    "s3tables:tables": "npx ts-node lib/tables/create-s3-tables.ts tables",
    "tag:release": "git tag v$(node -p \"require('./package.json').version\") && git push origin v$(node -p \"require('./package.json').version\")",
    "tag:prerelease": "git tag v$(node -p \"require('./package.json').version\")-rc.$(date +%Y%m%d.%H%M) && git push origin v$(node -p \"require('./package.json').version\")-rc.$(date +%Y%m%d.%H%M"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/jest": "^30.0.0",
    "@types/node": "22.16.4",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "aws-cdk": "2.1020.2",
    "aws-sdk-client-mock": "^4.1.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.31.0",
    "jest": "^30.0.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.0"
  },
  "dependencies": {
    "@aws-cdk/aws-lambda-event-sources": "^1.203.0",
    "@aws-cdk/aws-s3tables-alpha": "^2.202.0-alpha.0",
    "@aws-sdk/client-athena": "^3.787.0",
    "@aws-sdk/client-glue": "^3.787.0",
    "aws-cdk-lib": "2.204.0",
    "constructs": "^10.0.0",
    "dotenv": "^17.2.0"
  }
}
